{
  "name": "rmlui-bgfx",
  "version-string": "0.1.0",
  "dependencies": [
    "bgfx",
    {
      "name": "rmlui",
      "features": [
        "freetype"
      ]
    }
  ],
  "features": {
    "tests": {
      "description": "Build rmlui-bgfx unit tests.",
      "dependencies": [
        "catch2"
      ]
    },
    "shader-tools": {
      "description": "Install bgfx shader compiler tools for regenerating shader binaries.",
      "dependencies": [
        {
          "name": "bgfx",
          "features": [
            "tools"
          ]
        }
      ]
    },
    "samples": {
      "description": "Build the upstream RmlUi samples against the rmlui-bgfx SDL/bgfx backend.",
      "dependencies": [
        "sdl3",
        "stb",
        "lua",
        "harfbuzz",
        "rlottie",
        "lunasvg"
      ]
    }
  }
}
